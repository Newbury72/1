#!/usr/bin/env sh
# Self-contained wrapper: download Gradle 8.4 distribution and run it
APP_HOME="$(cd "$(dirname "$0")" && pwd)"
GRADLE_VERSION=8.4
DIST_DIR="$APP_HOME/gradle/wrapper/gradle-$GRADLE_VERSION"
ZIP="$APP_HOME/gradle/wrapper/gradle-$GRADLE_VERSION-all.zip"
DIST_URL="https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-all.zip"

if [ ! -d "$DIST_DIR" ]; then
  echo "Gradle $GRADLE_VERSION not found, downloading..."
  mkdir -p "$APP_HOME/gradle/wrapper"
  if command -v curl >/dev/null 2>&1; then
    curl -L "$DIST_URL" -o "$ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "$ZIP" "$DIST_URL"
  else
    echo "Neither curl nor wget found. Install one or generate the wrapper on another machine." >&2
    exit 1
  fi
  unzip -q -o "$ZIP" -d "$APP_HOME/gradle/wrapper"
fi

exec "$DIST_DIR/bin/gradle" "$@"
